config BR2_PACKAGE_RTL88X2BU
	bool "rtl88x2bu"
	depends on BR2_LINUX_KERNEL
	help
	  Out-of-tree Realtek RTL8812BU/RTL8822BU USB WiFi driver, sourced
	  from the morrownr fork (kernel-module package, P3.1). Not required
	  for wpa_supplicant -D nl80211 (see rtl88x2bu.mk for the
	  CONFIG_WIRELESS_EXT analysis).

	  https://github.com/morrownr/88x2bu-20210702

comment "rtl88x2bu needs a Linux kernel to be built"
	depends on !BR2_LINUX_KERNEL
