# /etc/inittab
#
# Copyright (C) 2001 Erik Andersen <andersen@codepoet.org>
#
# Note: BusyBox init doesn't support runlevels.  The runlevels field is
# completely ignored by BusyBox init. If you want runlevels, use
# sysvinit.
#
# Format for each entry: <id>:<runlevels>:<action>:<process>
#
# id        == tty to run on, or empty for /dev/console
# runlevels == ignored
# action    == one of sysinit, respawn, askfirst, wait, and once
# process   == program to run
#
# P2.3: reproduces stock's /etc/inittab (work/imgroot/etc/inittab) with two
# adaptations from stock, both documented in docs/init-parity.md:
#   1. The remount-rw line stays commented out, same as stock -- "/" is
#      read-only at boot (ADR 0011) and only becomes rw via /etc/profile's
#      own remount, on login. Buildroot's OWN skeleton default inittab has
#      this line UNCOMMENTED, which would defeat the whole read-only-root
#      design if left in place -- this file overrides that default.
#   2. The serial getty targets ttyS0 @ 115200 explicitly (BusyBox getty,
#      not util-linux agetty -- BR2_PACKAGE_UTIL_LINUX_BINARIES is not
#      selected) rather than stock's "console" alias, matching this board's
#      actual cmdline (docs/boot-chain.md: "console=ttyS0,115200").
#   3. loadkeys/setfont are dropped: this BusyBox build has no "loadkeys"
#      applet and CONFIG_SETFONT is not set (verified in
#      output/build/busybox-1.37.0/.config) -- keeping either line would
#      just fail every boot. gpm is kept (BR2_PACKAGE_GPM=y, binary present).

# Startup the system
::sysinit:/bin/mount -t proc proc /proc
#::sysinit:/bin/mount -o remount,rw /
::sysinit:/bin/mkdir -p /dev/pts /dev/shm
::sysinit:/bin/mount -a
# / is read-only, so /run (tmpfs) starts empty each boot. /var/lock -> /run/lock
# and /var/run -> /run, but nothing creates /run/lock, so daemons that take a
# lock (sshd, crond, ...) fail their `touch /var/lock/<name>`. Create it here,
# after `mount -a` has mounted the /run tmpfs.
::sysinit:/bin/mkdir -p /run/lock /run/lock/subsys
::sysinit:/media/fat/MiSTer &
::sysinit:/etc/resync &
::sysinit:/sbin/swapon -a
null::sysinit:/bin/ln -sf /proc/self/fd /dev/fd
null::sysinit:/bin/ln -sf /proc/self/fd/0 /dev/stdin
null::sysinit:/bin/ln -sf /proc/self/fd/1 /dev/stdout
null::sysinit:/bin/ln -sf /proc/self/fd/2 /dev/stderr
::sysinit:/bin/hostname -F /etc/hostname
# now run any rc scripts
::sysinit:/etc/init.d/rcS
# /usr/sbin, NOT stock's /sbin: gpm is a real package (not a BusyBox applet,
# which would land in /sbin regardless), and this build's rootfs is not
# usr-merged (verified: /sbin is a real directory, not -> /usr/sbin, unlike
# stock's work/imgroot) -- so /sbin/gpm does not exist. Same root cause as
# the /etc/profile PATH adaptation above.
::sysinit:/usr/sbin/gpm -m /dev/input/mice -t imps2

# Put a getty on the serial port (adapted from stock -- see note 2 above)
ttyS0::respawn:/sbin/getty -L ttyS0 115200 vt100

# Stuff to do for the 3-finger salute
#::ctrlaltdel:/sbin/reboot

# Stuff to do before rebooting
::shutdown:/etc/init.d/rcK
::shutdown:/sbin/swapoff -a
::shutdown:/bin/umount -a -r
