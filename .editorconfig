# EditorConfig helps maintain consistent coding styles for multiple developers
# working on the same project across various editors and IDEs.
# http://editorconfig.org

root = true

# Default settings for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Makefiles and Buildroot .mk files REQUIRE literal tabs (not spaces)
[{Makefile,*.mk}]
indent_style = tab

# Buildroot Config.in files: 8-space indent for help text (Kconfig convention)
[Config.in*]
indent_style = space
indent_size = 8

# Buildroot defconfigs and kernel configs are KEY=value; no indentation, no reflowing
[{*_defconfig,*.config}]
indent_style = space
trim_trailing_whitespace = false

# Kernel patch files: preserve trailing whitespace (context lines) and don't add final newline
[*.patch]
trim_trailing_whitespace = false
insert_final_newline = false

# Shell scripts
[*.sh]
indent_style = space
indent_size = 2

# Markdown
[*.md]
indent_style = space
indent_size = 2

# YAML
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# C source and headers
[*.{c,h}]
indent_style = space
indent_size = 4

# Python
[*.py]
indent_style = space
indent_size = 4
