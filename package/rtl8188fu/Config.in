config BR2_PACKAGE_RTL8188FU
	bool "rtl8188fu"
	depends on BR2_LINUX_KERNEL
	help
	  Out-of-tree Realtek RTL8188FU USB WiFi driver (kernel-module
	  package, P3.1). NOT sourced from morrownr — morrownr carries no
	  RTL8188FU repo; sourced instead from kelebek333/rtl8188fu, the
	  most actively maintained fork available (see rtl8188fu.mk for the
	  documented deviation and the CONFIG_WIRELESS_EXT analysis).

	  https://github.com/kelebek333/rtl8188fu

comment "rtl8188fu needs a Linux kernel to be built"
	depends on !BR2_LINUX_KERNEL
