# scripts/test-initramfs/qemu-test-kernel.config
#
# TASKS.md P1.12 / A7: "QEMU has no Cyclone V SoC machine model. CI runs ...
# the initramfs logic on a generic QEMU ARM machine." This fragment, merged
# onto multi_v7_defconfig (scripts/test-initramfs.sh does this via
# scripts/kconfig/merge_config.sh), builds a kernel `qemu-system-arm -M virt`
# can actually boot. It is NOT the DE10-Nano product kernel
# (board/mister/de10nano/linux.config) and never will be -- different SoC,
# different UART, no PL310, virtio instead of the real MMC/USB stack. Its only
# job is to run the REAL, unmodified initramfs cpio
# (output-initramfs/images/rootfs.cpio) far enough to prove /init's own logic.
#
# Promoted from work/p1.10-qemu/kernel-fragment.config (P1.10's throwaway
# harness) verbatim, plus NLS_CODEPAGE_437 kept for the mojibake case this
# harness exists to catch (see the "nonascii" fixture in test-initramfs.sh).

# Everything /init needs, on a generic ARM machine QEMU can actually run.
CONFIG_BLK_DEV_INITRD=y
CONFIG_RD_GZIP=y
CONFIG_BLK_DEV_LOOP=y
CONFIG_BLK_DEV_LOOP_MIN_COUNT=8
CONFIG_EXT4_FS=y
CONFIG_VFAT_FS=y
CONFIG_FAT_DEFAULT_UTF8=y
CONFIG_EXFAT_FS=y
CONFIG_NLS_CODEPAGE_437=y
CONFIG_NLS_ISO8859_1=y
CONFIG_NLS_UTF8=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_VIRTIO=y
CONFIG_VIRTIO_MMIO=y
CONFIG_VIRTIO_BLK=y
CONFIG_SERIAL_AMBA_PL011=y
CONFIG_SERIAL_AMBA_PL011_CONSOLE=y
