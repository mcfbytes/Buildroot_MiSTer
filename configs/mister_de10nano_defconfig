# --- P3.1/v9: Realtek USB WiFi -- MAINLINE-FIRST out-of-tree driver policy ---
# Commit-pinned, hash-verified morrownr forks, kept ONLY for the 802.11ac chips
# mainline still cannot drive: RTL8812AU, RTL8811AU/RTL8821AU and RTL8814AU.
# Their .ko lands under output/target/usr/lib/modules/6.18.38/ and is autoloaded
# by depmod/eudev on dongle insertion (P3.3). None need CONFIG_WIRELESS_EXT for
# wpa_supplicant -D nl80211 (per-package .mk documents the finding).
#
# The other Realtek USB chips MiSTer's 5.15 stock drove out-of-tree are now
# handled by IN-KERNEL drivers (board/mister/de10nano/linux.config), so their
# out-of-tree packages are DISABLED here -- enabling both would bind-fight on
# the same USB IDs:
#   8188eu, 8188fu, 8710bu  -> rtl8xxxu       (CONFIG_RTL8XXXU=m, already on)
#   8811cu, 8821cu          -> rtw88_8821cu   (CONFIG_RTW88_8821CU=m)
#   8822bu                  -> rtw88_8822bu   (CONFIG_RTW88_8822BU=m, HW-verified WPA3)
# The disabled packages stay sourced (Config.in) as a selectable fallback.
#
# rtl8188eu-aircrack-ng / rtl8821au-morrownr / rtl8821cu-morrownr / rtl8814au-
# morrownr carry a fork suffix, NOT plain rtl8188eu/rtl8821au/rtl8821cu -- so as
# not to collide with Buildroot 2026.02.3's own same-named upstream packages
# (different forks) on the Kconfig symbol and Make namespace. Buildroot's own
# rtl8188eu/rtl8821au/rtl8821cu/rtl8812au-aircrack-ng packages are left OFF --
# our pins stay in control, not Buildroot's release cadence (A9 reproducibility).
BR2_PACKAGE_RTL8812AU=y                          # RTL8812AU 11ac -- no mainline USB driver
BR2_PACKAGE_RTL8814AU_MORROWNR=y                 # RTL8814AU 4x4 11ac -- no mainline USB driver
BR2_PACKAGE_RTL8821AU_MORROWNR=y                 # RTL8811AU/RTL8821AU 11ac -- no mainline USB driver
# BR2_PACKAGE_RTL8188EU_AIRCRACK_NG is not set   # -> mainline rtl8xxxu (8188eu)
# BR2_PACKAGE_RTL8188FU is not set               # -> mainline rtl8xxxu (8188fu)
# BR2_PACKAGE_RTL8821CU_MORROWNR is not set      # -> mainline rtw88_8821cu (8811cu/8821cu)
# RTL8822BU (0bda:b812): SWITCHED to the MAINLINE rtw88 driver (kernel
# CONFIG_RTW88_8822BU=m, see board/.../linux.config) instead of the out-of-tree
# 88x2bu. Mainline goes through mac80211, so WPA3/SAE/PMF work correctly (the
# out-of-tree 88x2bu advertised SAE+CMAC but failed WPA3-only association,
# status_code=1 -- verified on hardware). rtw88 USB support for this chip landed
# in mainline ~6.2, AFTER stock's 5.15 froze -- which is why the out-of-tree
# driver was needed then and isn't now. The out-of-tree package is left OFF to
# avoid a bind conflict on the same USB ID; re-enable it (and drop RTW88_8822BU)
# to fall back. See docs/wifi-parity.md.
# BR2_PACKAGE_RTL88X2BU is not set

