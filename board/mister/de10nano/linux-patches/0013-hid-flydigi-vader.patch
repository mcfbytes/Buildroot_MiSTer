From b1b168eb64d0f34952cbf4ed05af74b5f00f630b Mon Sep 17 00:00:00 2001
From: Alexey Melnikov
Date: Wed, 15 Apr 2026 01:02:42 +0800
Subject: [PATCH 1/1] hid: add Flydigi Vader 4 Pro BT D-Input remap driver

New driver, hid-vader4.c. The Vader 4 Pro reports several of its
extra buttons (grip paddles, a 4th face button, MODE) as generic
consumer-page keys (KEY_ENTER/KEY_TV/KEY_CHANNELUP/etc.) when paired
over Bluetooth in D-Input mode. This driver's .event hook intercepts
those usages and re-reports them as BTN_C/BTN_Z/BTN_GRIPL(2)/
BTN_GRIPR(2)/BTN_TRIGGER_HAPPY3/BTN_MODE instead.

Provenance
----------
Origin:       b1b168eb64d0f34952cbf4ed05af74b5f00f630b
              "input: add HID driver to fix Flydigi Vader 4 Pro mapping
              in D-Input over Bluetooth."
              MiSTer-devel/Linux-Kernel_MiSTer, 2026-04-15, against v5.15.
              https://github.com/MiSTer-devel/Linux-Kernel_MiSTer/commit/b1b168eb64d0f34952cbf4ed05af74b5f00f630b
Author:       Alexey Melnikov (commit authored under the Sorgelig account).
Upstream:     No. Disposition "carry" (docs/patch-provenance.md class D).
Forward-port: 5.15 -> 6.18.38, Michael C. Ferguson, 2026-07-12, task P1.9.
              Compiles unmodified. BTN_GRIPL/BTN_GRIPL2/BTN_GRIPR/
              BTN_GRIPR2 are mainline UAPI since 97c01e65ef4c (v6.18) with
              the same numeric values the fork used locally; no header
              conflict.

Signed-off-by: Alexey Melnikov
Signed-off-by: Michael C. Ferguson <michael.christopher.ferguson@gmail.com>
---
diff --git a/drivers/hid/Kconfig b/drivers/hid/Kconfig
index c307afd11..ecfdff148 100644
--- a/drivers/hid/Kconfig
+++ b/drivers/hid/Kconfig
@@ -391,6 +391,14 @@ config HID_EZKEY
 	help
 	Support for Ezkey BTC 8193 keyboard.
 
+config HID_VADER4
+	tristate "Flydigi Vader 4 Pro in BT D-Input mode"
+	depends on HID
+	default !EXPERT
+	select INPUT_FF_MEMLESS
+	help
+	Remap weird Vader 4 Pro mapping over Bluetooth.
+
 config HID_FT260
 	tristate "FTDI FT260 USB HID to I2C host support"
 	depends on USB_HID && HIDRAW && I2C
diff --git a/drivers/hid/Makefile b/drivers/hid/Makefile
index 0c6f26d13..3ea9451d1 100644
--- a/drivers/hid/Makefile
+++ b/drivers/hid/Makefile
@@ -93,6 +93,7 @@ obj-$(CONFIG_HID_MCP2221)	+= hid-mcp2221.o
 obj-$(CONFIG_HID_MAYFLASH)	+= hid-mf.o
 obj-$(CONFIG_HID_MEGAWORLD_FF)	+= hid-megaworld.o
 obj-$(CONFIG_HID_MICROSOFT)	+= hid-microsoft.o
+obj-$(CONFIG_HID_VADER4)	+= hid-vader4.o
 obj-$(CONFIG_HID_MONTEREY)	+= hid-monterey.o
