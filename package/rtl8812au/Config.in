config BR2_PACKAGE_RTL8812AU
	bool "rtl8812au"
	depends on BR2_LINUX_KERNEL
	help
	  Out-of-tree Realtek RTL8812AU USB WiFi driver, sourced from the
	  morrownr fork (kernel-module package, P3.1). Not required for
	  wpa_supplicant -D nl80211 (see rtl8812au.mk for the
	  CONFIG_WIRELESS_EXT analysis).

	  https://github.com/morrownr/8812au-20210820

comment "rtl8812au needs a Linux kernel to be built"
	depends on !BR2_LINUX_KERNEL
