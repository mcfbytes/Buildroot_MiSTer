# --- MIDI / MT-32 (P3.8) ---
# munt (mt32d) + MidiLink reproduce stock's MIDI/MT-32 stack: MidiLink
# (usr/sbin/midilink, usr/sbin/mlinkutil) is the ALSA-seq client that shells
# out to mt32d (munt) or fluidsynth on demand. Neither has an upstream
# Buildroot package -- both authored under package/. See docs/midi-mt32-parity.md.
BR2_PACKAGE_MUNT=y
BR2_PACKAGE_MIDILINK=y
# alsa-utils MIDI tools -- stock ships amidi/aplaymidi/arecordmidi/aseqdump/
# aseqnet/aconnect (docs/stock-inventory/binaries-needed-full.txt), the tooling
# that exercises the ALSA-seq MIDI graph. NOTE: stock's GENERAL (non-MIDI) ALSA
# tools (alsactl/alsamixer/aplay/arecord/amixer/...) are a separate parity gap,
# tracked outside P3.8 -- see docs/midi-mt32-parity.md.
